{
  "name": "isometric-perspective",
  "version": "0.9.7",
  "description": "Isometric Module for Foundry VTT v13+",
  "type": "module",
  "dependencies": {
    "archiver": "^5.3.1"
  },
  "scripts": {
    "build": "node release.cjs",
    "release:check": "node release-check.cjs",
    "release:publish": "node release-publish.cjs",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint scripts docs release.cjs release-check.cjs release-publish.cjs",
    "lint:fix": "eslint scripts docs release.cjs release-check.cjs release-publish.cjs --fix",
    "harness:high-risk": "node scripts/high-risk-harness.js --file high-risk-harness.json",
    "harness:occlusion-baseline": "node scripts/occlusion-baseline-harness.js --file occlusion-baseline-run.json"
  },
